rules_version = '2';

// Shelf Tracker — private. Only these Google accounts may read or write.
// Owner chose Google sign-in + an email allow-list (2026-06-17). To add someone,
// add their Google email below and run: npx firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function allowed() {
      return request.auth != null
        && request.auth.token.email in [
          'zhongzm8e@gmail.com',
          'yna.palette@gmail.com'
        ];
    }
    match /{document=**} {
      allow read, write: if allowed();
    }
  }
}
